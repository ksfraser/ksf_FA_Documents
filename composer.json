{
    "name": "ksfraser/ksf-fa-documents",
    "description": "FA module for Document Management with multi-entity linking, ACL, and shared attachments",
    "type": "fa-module",
    "license": "GPL-3.0",
    "require": {
        "php": ">=7.4",
        "ksfraser/traits": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "files": [
            "includes/documents_db.inc"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../Traits"
        }
    ]
}
